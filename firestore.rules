rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ameeraltaleb@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isTimestamp(val) {
      return val is number || val is timestamp;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category']) &&
             data.size() >= 2 && data.size() <= 5 &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             (!('image' in data) || (data.image is string && data.image.size() <= 1000)) &&
             (!('images' in data) || (data.images is list && data.images.size() <= 20 && (data.images.size() == 0 || data.images[0] is string))) &&
             (!('createdAt' in data) || isTimestamp(data.createdAt));
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'icon', 'description']) &&
             data.size() >= 3 && data.size() <= 4 &&
             data.title is string && data.title.size() <= 100 &&
             data.icon is string && data.icon.size() <= 50 &&
             data.description is string && data.description.size() <= 500 &&
             (!('createdAt' in data) || isTimestamp(data.createdAt));
    }

    function isValidSetting(data) {
      return data.keys().hasAll(['value']) &&
             data.size() >= 1 && data.size() <= 2 &&
             data.value is string && data.value.size() <= 10000 &&
             (!('updatedAt' in data) || isTimestamp(data.updatedAt));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message']) &&
             data.size() >= 3 && data.size() <= 5 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.message is string && data.message.size() <= 2000 &&
             (!('createdAt' in data) || isTimestamp(data.createdAt)) &&
             (!('status' in data) || (data.status is string && data.status in ['new', 'read']));
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isAdmin() && isValidProject(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'image', 'images'])
      );
      allow delete: if isAdmin() && isValidId(projectId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(serviceId) && isValidService(incoming());
      allow update: if isAdmin() && isValidService(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'icon', 'description'])
      );
      allow delete: if isAdmin() && isValidId(serviceId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(settingId) && isValidSetting(incoming());
      allow update: if isAdmin() && isValidSetting(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['value', 'updatedAt'])
      );
      allow delete: if isAdmin() && isValidId(settingId);
    }

    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      // Admins are managed from the Firebase console, no one can write to this via client
      allow read: if isSignedIn() && isValidId(adminId) && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
